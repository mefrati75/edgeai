<section id="approach" class="py-32 sm:py-40 px-6 bg-neutral-50">
  <div class="max-w-2xl mx-auto">
    <h2 class="text-xs font-medium tracking-[0.3em] uppercase text-neutral-400 text-center mb-20">
      How We Work
    </h2>

    <div class="space-y-16">
      <div class="fade-in">
        <div class="flex items-baseline gap-6">
          <span class="text-neutral-300 text-sm font-medium tabular-nums">01</span>
          <div>
            <h3 class="font-serif text-2xl text-neutral-900 mb-2">Identify</h3>
            <p class="text-neutral-500 text-sm leading-relaxed">
              We find opportunities where AI can build an entire business — not just a feature.
            </p>
          </div>
        </div>
      </div>

      <div class="fade-in">
        <div class="flex items-baseline gap-6">
          <span class="text-neutral-300 text-sm font-medium tabular-nums">02</span>
          <div>
            <h3 class="font-serif text-2xl text-neutral-900 mb-2">Build</h3>
            <p class="text-neutral-500 text-sm leading-relaxed">
              AI-native development. Entire products conceived and built at machine speed.
            </p>
          </div>
        </div>
      </div>

      <div class="fade-in">
        <div class="flex items-baseline gap-6">
          <span class="text-neutral-300 text-sm font-medium tabular-nums">03</span>
          <div>
            <h3 class="font-serif text-2xl text-neutral-900 mb-2">Launch</h3>
            <p class="text-neutral-500 text-sm leading-relaxed">
              From zero to market. Real businesses with real users.
            </p>
          </div>
        </div>
      </div>

      <div class="fade-in">
        <div class="flex items-baseline gap-6">
          <span class="text-neutral-300 text-sm font-medium tabular-nums">04</span>
          <div>
            <h3 class="font-serif text-2xl text-neutral-900 mb-2">Scale</h3>
            <p class="text-neutral-500 text-sm leading-relaxed">
              Edge-first architecture means near-zero infrastructure cost at any scale.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
